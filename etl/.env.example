# Copy to etl/.env (gitignored) and paste your FREE UN Comtrade API key.
# Register (free): https://comtradedeveloper.un.org/  -> Sign in -> Subscribe to
# "Comtrade - v1" (free tier) -> Profile -> copy the Primary key.
# With this set, `python -m tradepulse_etl --source comtrade` switches to the authenticated
# monthly path (quarterly signals + partner breakdown). Without it, keyless annual World-only.
COMTRADE_SUBSCRIPTION_KEY=
CENSUS_API_KEY=
ESTAT_APP_ID=
KCS_SERVICE_KEY=
API_DATA_GOV_KEY=
USDA_API_KEY=
USDA_API_KEY_2=
USDA_API_KEY_3=